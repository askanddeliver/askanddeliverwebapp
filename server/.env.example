PORT=3001
NODE_ENV=development

# Primary admin email - always grants admin (fixes signup order)
# PRIMARY_ADMIN_EMAIL=your-email@example.com

# MongoDB
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/askanddeliver?retryWrites=true&w=majority

# Auth0
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=http://localhost:3001/api

# For add-by-email: create M2M app in Auth0, authorize Management API with read:users
# AUTH0_M2M_CLIENT_ID=
# AUTH0_M2M_CLIENT_SECRET=

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# --- Production (set these in Railway/Render dashboard) ---
# NODE_ENV=production
# CLIENT_URL=https://askanddeliver.com,https://www.askanddeliver.com
# AUTH0_AUDIENCE=https://api.askanddeliver.com/api
